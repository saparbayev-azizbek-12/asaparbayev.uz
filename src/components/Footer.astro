    <div>
      <p class="text-sm text-muted">
        Built with <a href="https://astro.build" target="_blank" class="text-accent hover:underline">Astro</a> & <a href="https://tailwindcss.com" target="_blank" class="text-accent hover:underline">Tailwind CSS</a>.
      </p>
    </div>
  </div>
</footer>
